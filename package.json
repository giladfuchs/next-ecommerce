{
  "name": "next-ecommerce",
  "version": "1.0.0",
  "private": true,
  "description": "Full-stack monorepo: Next.js frontend with backend logic using TypeORM via serverless functions",
  "author": "GILAD",
  "license": "MIT",
  "scripts": {
    "prebuild": "cp vercel.function.json vercel.json || true",
    "build": "pnpm prepare:api && pnpm --dir frontend build",
    "dev": "pnpm --dir frontend dev",
    "start": "pnpm --dir frontend start",
    "build:backend": "pnpm --dir backend build",
    "copy:functions": "rm -rf frontend/app/functions && mkdir -p frontend/app/functions && cp -r backend/functions/* frontend/app/functions/",
    "prepare:api": "pnpm build:backend && pnpm copy:functions"
  },
  "dependencies": {
    "@emotion/react": "11.11.1",
    "@emotion/styled": "11.11.0",
    "@mui/icons-material": "5.15.15",
    "@mui/material": "5.15.15",
    "@mui/system": "5.15.15",
    "@mui/x-tree-view": "8.3.1",
    "@reduxjs/toolkit": "^2.7.0",
    "@vercel/analytics": "^1.5.0",
    "ag-grid-community": "29.3.3",
    "ag-grid-react": "29.3.3",
    "clsx": "^2.1.1",
    "dotenv": "^16.3.1",
    "formik": "^2.4.6",
    "geist": "^1.3.1",
    "jsonwebtoken": "^9.0.2",
    "multer": "1.4.5-lts.2",
    "next": "14.2.3",
    "pg": "^8.15.6",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-intl": "^7.1.11",
    "react-redux": "^9.2.0",
    "redux-persist": "^6.0.0",
    "reflect-metadata": "^0.2.2",
    "sonner": "^2.0.3",
    "typeorm": "^0.3.22",
    "yup": "^1.6.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "@tailwindcss/container-queries": "^0.1.1",
    "@tailwindcss/postcss": "^4.0.14",
    "@tailwindcss/typography": "^0.5.16",
    "@types/node": "22.13.10",
    "@types/react": "18.2.8",
    "@types/react-dom": "18.2.4",
    "postcss": "^8.5.3",
    "prettier": "3.5.3",
    "prettier-plugin-tailwindcss": "^0.6.11",
    "sass": "^1.86.3",
    "tailwindcss": "^4.0.14",
    "typescript": "5.8.2"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "packageManager": "pnpm@10.8.1"
}