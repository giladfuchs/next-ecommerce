{
  "name": "next-ecommerce-monorepo",
  "private": true,
  "scripts": {
    "pack:backend": "cd backend && pnpm build && pnpm pack && cd .. && mv backend/*.tgz functions/next-ecommerce-backend.tgz && pnpm add ./functions/next-ecommerce-backend.tgz",
    "prepare:frontend": "pnpm copy:frontend && pnpm copy:functions",
    "copy:frontend": "cp -r frontend/app frontend/components frontend/lib frontend/public . && cp frontend/next.config.js frontend/postcss.config.mjs frontend/tailwind.config.js frontend/next-env.d.ts frontend/middleware.ts .",
    "copy:functions": "mkdir -p app/api && cp -r functions/api/* app/api/",
    "build": "cp functions/tsconfig.json . && pnpm install && pnpm prepare:frontend && next build"
  },
  "dependencies": {
    "next-ecommerce-backend": "file:functions/next-ecommerce-backend.tgz",
    "@emotion/react": "11.11.4",
    "@emotion/styled": "11.11.5",
    "@mui/icons-material": "7.2.0",
    "@mui/material": "7.2.0",
    "@mui/system": "7.2.0",
    "@mui/x-tree-view": "8.7.0",
    "@reduxjs/toolkit": "^2.7.0",
    "@vercel/analytics": "^1.5.0",
    "@vercel/blob": "^1.0.0",
    "@vercel/node": "^5.2.1",
    "ag-grid-community": "29.3.3",
    "ag-grid-react": "29.3.3",
    "bcryptjs": "^3.0.2",
    "clsx": "^2.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.0.0",
    "express": "^4.18.2",
    "formik": "^2.4.6",
    "geist": "^1.3.1",
    "jsonwebtoken": "^9.0.2",
    "multer": "1.4.5-lts.2",
    "next": "14.2.3",
    "nodemailer": "^6.10.1",
    "pg": "^8.15.6",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-intl": "7.1.11",
    "react-redux": "^9.2.0",
    "redux-persist": "^6.0.0",
    "reflect-metadata": "^0.2.2",
    "sharp": "^0.34.1",
    "sonner": "^2.0.3",
    "typeorm": "^0.3.22",
    "yup": "^1.6.1"
  },
  "devDependencies": {
    "@faker-js/faker": "^9.7.0",
    "@playwright/test": "1.53.2",
    "@tailwindcss/container-queries": "^0.1.1",
    "@tailwindcss/postcss": "^4.0.14",
    "@tailwindcss/typography": "^0.5.16",
    "@types/bcryptjs": "^3.0.0",
    "@types/cookie-parser": "^1.4.8",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/multer": "^1.4.12",
    "@types/node": "22.13.10",
    "@types/nodemailer": "^6.4.17",
    "@types/react": "18.2.0",
    "@types/react-dom": "18.2.0",
    "@types/supertest": "^6.0.3",
    "nodemon": "^3.1.10",
    "postcss": "^8.5.3",
    "prettier": "3.5.3",
    "prettier-plugin-tailwindcss": "^0.6.11",
    "sass": "^1.86.3",
    "supertest": "^7.1.0",
    "tailwindcss": "^4.0.14",
    "ts-node": "^10.9.2",
    "tsx": "^4.19.4",
    "typescript": "5.8.2",
    "vitest": "^3.1.3"
  },
  "packageManager": "pnpm@10.8.1"
}