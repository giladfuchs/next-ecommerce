{
  "name": "next-ecommerce-monorepo",
  "private": true,
  "scripts": {
    "prepare:frontend": "pnpm copy:frontend",
    "copy:frontend": "cp -r ../frontend/app frontend/components frontend/lib frontend/public . && cp frontend/next.config.js frontend/postcss.config.mjs frontend/tailwind.config.js frontend/next-env.d.ts frontend/middleware.ts .",
    "vercel-build": "pnpm prepare:frontend && ../node_modules/.bin/next build"
  },
  "dependencies": {
    "@emotion/react": "11.11.1",
    "@emotion/styled": "11.11.0",
    "@mui/icons-material": "5.15.15",
    "@mui/material": "5.15.15",
    "@mui/system": "5.15.15",
    "@mui/x-tree-view": "8.3.1",
    "@reduxjs/toolkit": "^2.7.0",
    "@vercel/analytics": "^1.5.0",
    "ag-grid-community": "29.3.3",
    "ag-grid-react": "29.3.3",
    "clsx": "^2.1.1",
    "formik": "^2.4.6",
    "geist": "^1.3.1",
    "next": "14.2.3",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-intl": "^7.1.11",
    "react-redux": "^9.2.0",
    "redux-persist": "^6.0.0",
    "sonner": "^2.0.3",
    "yup": "^1.6.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "@tailwindcss/container-queries": "^0.1.1",
    "@tailwindcss/postcss": "^4.0.14",
    "@tailwindcss/typography": "^0.5.16",
    "@types/node": "22.13.10",
    "@types/react": "18.2.8",
    "@types/react-dom": "18.2.4",
    "@vercel/node": "^5.2.1",
    "postcss": "^8.5.3",
    "prettier": "3.5.3",
    "prettier-plugin-tailwindcss": "^0.6.11",
    "sass": "^1.86.3",
    "tailwindcss": "^4.0.14",
    "typescript": "5.8.2"
  },
  "packageManager": "pnpm@10.8.1"
}
